{
  "name": "agora-sdk-js",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for AGORA Instance.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.20.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}